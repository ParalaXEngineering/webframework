{% extends 'base.j2' %}
{% block js %}
<script>
  // ---- Helpers -------------------------------------------------------------
  function buildAjaxConfig(url) {
    return {
      url,
      type: 'GET',
      // CRITICAL: Forward all DataTables params (including SearchPanes params)
      data: function(d) { return d; },
      dataSrc: function (json) {
        if (!json) return [];
        if (Array.isArray(json.data)) return json.data;   // DT SSP
        if (Array.isArray(json.items)) return json.items; // alt
        if (Array.isArray(json.results)) return json.results;
        if (Array.isArray(json)) return json;
        return [];
      }
    };
  }

  // Get a DataTable instance regardless of jQuery / vanilla build
  function getDTInstance(el) {
    if (window.jQuery && $.fn && $.fn.dataTable) {
      if ($.fn.dataTable.isDataTable(el)) return $(el).DataTable();
      return null;
    }
    if (window.DataTable) {
      try {
        // In DT2 vanilla this returns the existing instance if already initialised
        const dt = DataTable(el);
        // Guard: only treat as instance if initialised
        if (dt && typeof dt.draw === 'function') return dt;
      } catch (e) { /* not initialised yet */ }
    }
    return null;
  }

  {% if 'responsive_addon' in content['all_layout'] %}
    {% for table_id, addon in content['all_layout']['responsive_addon'].items() %}
      {% set is_ssp = 'ajax' in addon.get('type') or 'server_side' in addon.get('type') %}

      {% if addon.get('data') %}
        const tableData_{{ table_id }} = {{ addon['data'] | safe }};
      {% endif %}

      (function initDT_{{ table_id }}() {
        {% set all_indices = range(0, addon['ajax_columns']|length) %}
        {# Logic: None or not present = all columns, [] = no panes, [1,2] = specific columns #}
        {% if 'columns' in addon and addon.columns is not none %}
          {% set pane_indices = addon.columns %}
          {% set panes_disabled = (addon.columns|length == 0) %}
        {% else %}
          {% set pane_indices = all_indices|list %}
          {% set panes_disabled = false %}
        {% endif %}
        {% set non_pane_indices = [] %}
        {% for i in all_indices %}
          {% if i not in pane_indices %}
            {% set _ = non_pane_indices.append(i) %}
          {% endif %}
        {% endfor %}

        const tableSelector = '#{{addon.get('type')}}_{{ table_id }}';

        // DEBUG: Log what columns we're trying to show/hide
        console.log('Table: {{ table_id }}');
        console.log('  Total columns: {{ addon['ajax_columns']|length }}');
        console.log('  Pane indices (should show): {{ pane_indices|list }}');
        console.log('  Panes disabled: {{ panes_disabled }}');
        console.log('  Non-pane indices (should hide): {{ non_pane_indices|list }}');

        {% if not panes_disabled %}
        // Build SearchPanes config (only if panes are enabled)
        // CRITICAL: In DT2 with layout API, you MUST specify columns array to force show/hide
        const panesConfig_{{ table_id }} = {
          cascadePanes: true,
          columns: {{ pane_indices|list }},  // Only show panes for these column indices
          {% if is_ssp %}
          viewTotal: true
          {% endif %}
        };
        {% endif %}

        const opts_{{ table_id }} = {
          {% if addon.get('data') and not is_ssp %}
          data: tableData_{{ table_id }},
          {% endif %}

          {% if is_ssp %}
          serverSide: true,
          processing: true,
          ajax: buildAjaxConfig("{{ addon.get('api') | url_for_with_params(addon.get('api_params')) }}"),
          {% endif %}

          // Scroller and SSP both require paging enabled
          paging: true,

          columns: [
            {% for column in addon['ajax_columns'] %}
              { data: '{{ column["data"] }}', defaultContent: '' },
            {% endfor %}
          ],

          {% if not panes_disabled %}
          columnDefs: [
            {% if not is_ssp %}
            // Custom render function for SearchPanes with orthogonal data
            // This enables comma-separated values to be split into individual options
            // (Only for client-side modes; SSP gets options from the server response)
            {
              searchPanes: {
                orthogonal: 'sp'  // Use 'sp' type for SearchPanes processing
              },
              targets: {{ pane_indices|list }},
              render: function (data, type, row, meta) {
                if (data == null || data === '') return '';

                // For SearchPanes orthogonal data (type === 'sp')
                if (type === 'sp') {
                  var strData = data;
                  
                  // Handle arrays
                  if (Array.isArray(data)) {
                    strData = data.join(',');
                  } else if (typeof data === 'object') {
                    // If it's an object, try to stringify it
                    strData = JSON.stringify(data);
                  } else if (typeof data !== 'string') {
                    strData = String(data);
                  }
                  
                  // Strip HTML tags
                  var stripped = strData.replace(/<\/?[^>]+(>|$)/g, '');
                  
                  // Split by comma and trim, return array for SearchPanes
                  return stripped.split(',').map(function(item) { 
                    return item.trim(); 
                  }).filter(function(item) { 
                    return item.length > 0; 
                  });
                }
                
                // For all other types (display, filter, sort), return data as-is
                return data;
              }
            }
            {% else %}
            // SSP mode: force panes to show for these columns.
            // The server returns searchPanes.options keyed by field name.
            {
              searchPanes: {
                show: true
              },
              targets: {{ pane_indices|list }}
            }
            {% endif %}
          ],
          {% endif %}

          stateSave: true,

          // DT2: layout configuration
          layout: {
            {% if not panes_disabled %}
            top: 'searchPanes',
            {% endif %}
            topStart: 'pageLength',
            topEnd: 'search',
            bottomStart: 'info',
            bottomEnd: 'paging'
          }
          
          {% if not panes_disabled %}
          // SearchPanes configuration (only if panes are enabled)
          ,searchPanes: panesConfig_{{ table_id }}
          {% endif %}

          {% if addon.get("order") %},
          order: {{ addon["order"] | tojson }}
          {% endif %}
          {% if addon.get("pageLength") %},
          pageLength: {{ addon["pageLength"] }}
          {% endif %}
        };

        {% if addon.get('type') == 'reorderable' %}
        // RowReorder extension configuration for DOM-based tables
        opts_{{ table_id }}.rowReorder = {
          update: false,  // Don't let RowReorder auto-update - we handle it manually
          selector: 'td:first-child',  // Drag from first column (name with icon)
          snapX: true  // Constrain horizontal movement
        };
        
        // Disable all sorting to preserve DOM order (database order)
        opts_{{ table_id }}.ordering = false;
        
        // Disable paging for reorderable tables to see all rows
        opts_{{ table_id }}.paging = false;
        {% endif %}

        // If you actually use Scroller elsewhere, ensure the flags are coherent
        {% if addon.get('scroller') %}
        opts_{{ table_id }}.scroller = true;
        opts_{{ table_id }}.deferRender = true;
        {% endif %}

        // Initialize DataTable and capture instance
        const dt_{{ table_id }} = initializeDataTable(tableSelector, opts_{{ table_id }}, {{ 'true' if is_ssp else 'false' }});
        
        {% if addon.get('type') == 'reorderable' %}
        // Attach reorder event handler using DataTable API directly (not jQuery)
        dt_{{ table_id }}.on('row-reorder', function(e, diff, edit) {
          if (diff.length > 0) {
            console.log('[REORDER] Row reorder event triggered');
            console.log('[REORDER] Diff:', diff);
            
            // Wait for DOM to update, then extract order
            setTimeout(function() {
              const orderData = {};
              
              // Extract order from DOM after reorder (not from DataTable data)
              const table = document.querySelector(tableSelector);
              const rows = table.querySelectorAll('tbody tr');
              
              rows.forEach((row, index) => {
                // Get first cell (Name column with drag icon)
                const firstCell = row.querySelector('td:first-child');
                if (firstCell) {
                  // Extract text content (this will skip HTML tags like the icon)
                  const attrName = firstCell.textContent.trim();
                  orderData[attrName] = index;
                  console.log(`[REORDER] Row ${index}: ${attrName}`);
                }
              });
              
              console.log('[REORDER] New order map:', orderData);
            
              // Update hidden form field (unified format with form prefix)
              const hiddenField = $('input[name$=".attribute_order"]');
              console.log('[REORDER] Looking for hidden field, found:', hiddenField.length);
              if (hiddenField.length) {
                const jsonValue = JSON.stringify(orderData);
                hiddenField.val(jsonValue);
                console.log('[REORDER] Updated hidden field "' + hiddenField.attr('name') + '" with:', jsonValue);
              } else {
                console.error('[REORDER] Hidden field not found! Available inputs:', $('input').map(function() { return $(this).attr('name'); }).get());
              }
            }, 100);  // Wait 100ms for DOM to update
          }
        });
        {% endif %}
      })();
    {% endfor %}
  {% endif %}

  // Global function to save table order (for RowReorder)
  window.saveTableOrder = function(tableId) {
    alert('saveTableOrder called with: ' + tableId);
    console.log('[REORDER] saveTableOrder called with tableId:', tableId);
    
    const $table = $('#' + tableId);
    console.log('[REORDER] Table element found:', $table.length > 0);
    
    if (!$table.length) {
      alert('Table not found: ' + tableId);
      return;
    }
    
    const dataTable = $table.DataTable();
    const reorderCallback = $table.data('reorder-callback');
    console.log('[REORDER] Reorder callback URL:', reorderCallback);
    
    if (!reorderCallback) {
      alert('No save endpoint configured for this table');
      return;
    }
    
    // Build order array from current table state
    const orderData = [];
    dataTable.rows({order: 'current'}).every(function(rowIdx, tableLoop, rowLoop) {
      const data = this.data();
      // For HTML tables: data is array [order, name, ...]
      // Column 0 is order (hidden), column 1 is name with drag icon
      let attrName;
      if (Array.isArray(data)) {
        // Extract name from column 1, removing HTML tags (drag icon)
        const nameHtml = data[1] || '';
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = nameHtml;
        attrName = tempDiv.textContent.trim();
      } else {
        attrName = data.name || data.Name;
      }
      orderData.push({
        name: attrName,
        order: rowLoop
      });
    });
    
    console.log('[REORDER] Order data to send:', orderData);
    
    // Disable button and show loading
    const saveBtn = $('#save_order_' + tableId);
    saveBtn.prop('disabled', true)
           .html('<i class="mdi mdi-loading mdi-spin"></i> Saving...');
    
    // POST to callback URL
    console.log('[REORDER] Sending POST to:', reorderCallback);
    fetch(reorderCallback, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ reorder: orderData })
    })
    .then(response => {
      console.log('[REORDER] Response status:', response.status);
      return response.json();
    })
    .then(data => {
      console.log('[REORDER] Response data:', data);
      if (data.success) {
        // Success feedback
        saveBtn.removeClass('btn-primary')
               .addClass('btn-success')
               .html('<i class="mdi mdi-check"></i> Saved');
        
        // Reset button after 2 seconds
        setTimeout(function() {
          saveBtn.html('<i class="mdi mdi-content-save"></i> Save Order')
                 .removeClass('btn-success')
                 .addClass('btn-secondary')
                 .prop('disabled', true);
        }, 2000);
      } else {
        alert('Failed to update order: ' + (data.error || 'Unknown error'));
        saveBtn.html('<i class="mdi mdi-content-save"></i> Save Order')
               .removeClass('btn-secondary')
               .addClass('btn-primary')
               .prop('disabled', false);
      }
    })
    .catch(error => {
      console.error('[REORDER] Error:', error);
      alert('Error updating order: ' + error);
      saveBtn.html('<i class="mdi mdi-content-save"></i> Save Order')
             .removeClass('btn-secondary')
             .addClass('btn-primary')
             .prop('disabled', false);
    });
  };

  // ---- Tab redraw: safe for jQuery and vanilla builds ----------------------
  document.addEventListener('DOMContentLoaded', function () {
    const tabTriggers = document.querySelectorAll('[data-bs-toggle="tab"]');
    tabTriggers.forEach(function (tabTrigger) {
      tabTrigger.addEventListener('shown.bs.tab', function (event) {
        const targetId = event.target.getAttribute('href');
        if (!targetId) return;
        const targetPane = document.querySelector(targetId);
        if (!targetPane) return;

        // Small delay to ensure tab is fully visible
        setTimeout(function() {
          const tables = targetPane.querySelectorAll('table.dataTable, table.dt-table');
          tables.forEach(function (table) {
            const dt = getDTInstance(table);
            if (dt) {
              // Adjust column widths
              if (dt.columns && typeof dt.columns().adjust === 'function') {
                dt.columns().adjust();
              }
              
              // Force SearchPanes to recalculate by destroying and rebuilding
              if (dt.searchPanes) {
                try {
                  // Try different methods to rebuild SearchPanes
                  if (typeof dt.searchPanes.rebuild === 'function') {
                    dt.searchPanes.rebuild();
                  } else if (typeof dt.searchPanes.rebuildPane === 'function') {
                    dt.searchPanes.rebuildPane();
                  } else {
                    // Force a full redraw which should trigger SearchPanes resize
                    dt.draw();
                  }
                } catch (e) {
                  console.log('SearchPanes rebuild failed, trying draw:', e);
                  dt.draw();
                }
              } else {
                // No searchPanes API, just redraw
                dt.draw(false);
              }
            }
          });
          
          // Also trigger a window resize event which some DataTables plugins listen to
          window.dispatchEvent(new Event('resize'));
        }, 50);
      });
    });
  });
  
  // Tooltip system initialization
  {% if content.tooltips and content.tooltips|length > 0 %}
  window.tooltipData = {{ content.tooltips | tojson | safe }};
  {% if content.tooltip_allowed_elements %}
  window.tooltipAllowedElements = {{ content.tooltip_allowed_elements | tojson | safe }};
  {% endif %}
  {% endif %}
</script>

{% if content.tooltips and content.tooltips|length > 0 %}
<script src="{{ url_for('static', filename='js/tooltip_init.js') }}"></script>
{% endif %}

{% endblock %}



{% block title %}
{% if content["title"]%}
    {{content["title"]}}
{% endif %}
{% endblock %}

{% block main_page %}

{% if history is not defined %}
    {% set history = None %}
{% endif %}

{% set submenu_count = namespace(value=0) %}
{% set path_count = namespace(value=0) %}

{% with messages = get_flashed_messages(with_categories=true) %}
  {% if messages %}
    {% for category, message in messages %}
      {% set bs = category if category in ['primary','secondary','success','danger','warning','info','light','dark'] else 'secondary' %}
      <div class="alert alert-{{ bs }} alert-dismissible fade show mt-2" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    {% endfor %}
  {% endif %}
{% endwith %}

<script>
  document.querySelectorAll('.alert').forEach(a=>{
    setTimeout(()=>{ a.classList.remove('show'); a.addEventListener('transitionend',()=>a.remove()); }, 3500);
  });
</script>

{% if content|length <= 3 %}
    <div class="text-center">
        <img src="{{ url_for('static', filename= 'images/status/unauthorized.svg')}}" width="500vw">
        <h1 class="error-title">Unauthorized</h1>
        <p class="fs-5 text-gray-600">There is no tools that you are authorized to use in this section</p>
    </div>
{% else %}
    {% for modal in content["modals"] %}
    <div class="modal fade" id="{{modal["id"]}}" tabindex="-1" aria-labelledby="Coucou" aria-hidden="true" style="display: none;">
        <div class="modal-dialog modal-dialog-scrollable modal-full" role="document">
            <div class="modal-content">
                {% if "header" in modal %}
                <div class="modal-header">
                  <h5 class="modal-title">{{ modal["header"] }}</h5>
                </div>
                {% endif %}
                <div class="modal-body">
                {% for module in modal["content"] %}
                    {% if module != "modals" %}
                        {% for layout in modal["content"][module]["layouts"] %}

                            {% if layout["subtitle"] and layout["type"] != "SPACER" and layout.get("style") != "alert-card" %}
                                <h3 class="text-primary mt-5">{{layout["subtitle"]}}</h3>
                            {% endif %}

                            {% if layout["type"] == "VERT" %}
                                {{ disp_layouts.display_vertical_layout(layout["columns"], layout["containers"], layout["align"]) }}
                            {% elif layout["type"] == "TABLE" %}
                                {{ disp_layouts.display_table_layout(layout["header"], layout["lines"]) }}
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                {% endfor %}
                </div>
            </div>
        </div>
    </div>
    {% endfor %}

    {% for module in content %}
        {% if module != "modals" and module != "all_layout" and module != "breadcrumbs" and module != "title" and module != "required_css" and module != "required_js" and module != "required_cdn" and module != "required_css_cdn" and module != "tooltips" and module != "tooltip_allowed_elements" %}
            {% if content[module].get("layouts") or content[module].get("error") or content[module].get("type") in ["threaded_action", "workflow"] %}
            <div class="card">
                <div class="card-header py-1"></div>

                <div class="card-body">
                    {% if content[module]["display"] %}
                        {% if "name_override" in content[module] %}
                        <h1>{{ content[module]["name_override"] }}</h1>
                        {% else %}
                        <h1>{{ module }}</h1>
                        {% endif %}
                    {% endif %}

                    {% if "error" in content[module] and content[module]["error"] %}
                        <div class="text-center">
                            <img src="{{ url_for('static', filename='images/site/500.png')}}" style="width: 500px; max-width: 100%;">
                            <h3 class="error-title mt-3">This page can't be displayed with the current configuration</h3>
                            <p class="fs-5 text-gray-600">{{content[module]["error"]}}</p>
                        </div>
                    {#{% elif "access_denied" in content[module] and content[module]["access_denied"] %}
                        <div class="text-center">
                            <img src="{{ url_for('static', filename='images/site/unauthorized.png')}}" style="width: 500px; max-width: 100%;">
                            <div class="alert alert-light-danger color-danger">Access Denied</div>
                            <p class="fs-5 text-gray-600">
                                {% if "denied_reason" in content[module] and content[module]["denied_reason"] %}
                                    {{content[module]["denied_reason"]}}
                                {% else %}
                                    {% if "required_permission" in content[module] and content[module]["required_permission"] %}
                                      <p class="text-muted">
                                          <small>
                                              Required: '{{ content[module]["required_action"] }}' permission for '{{ content[module]["required_permission"] }}' module
                                          </small>
                                      </p>
                                  {% endif %}
                                {% endif %}
                            </p>
                        </div>#}
                    {% else %}

                        {% if target %}
                            <form action="{{ url_for(target) }}" method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        {% elif form_action %}
                            <form action="{{ form_action }}" method="POST" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
                        {% endif %}

                        {% for layout in content[module]["layouts"] %}
                            {% if layout["subtitle"] and layout["type"] != "SPACER" and layout["style"] != "alert-card" %}
                                <h3 class="text-primary mt-5">{{layout["subtitle"]}}</h3>
                            {% endif %}
                            {{ disp_layouts.display_layout(layout) }}
                        {% endfor %}

                        {% if target or form_action %}
                            </form>
                        {% endif %}

                    {% endif %}
                </div>

                {% if content[module]["type"] == "threaded_action" or content[module]["type"] == "workflow" %}
                    <div class="card-footer alert-light-secondary theme-aware">
                        <h4 class="theme-text">Action progress</h4>
                        <div class="table-responsive">
                            <table class="table-light table-striped mb-0 theme-aware" id="{{module | replace(' ', '_')}}_result">
                                <thead>
                                    <tr>
                                        <th style="width: 50%;">Task</th>
                                        <th style="width: 50%;">Status</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                        <div id="{{module | replace(' ', '_')}}_progress"></div>
                    </div>
                {% endif %}
            </div>
            {% endif %}
        {% endif %}
    {% endfor %}
{% endif %}

{% if thread_monitor_js %}
<script src="{{ url_for('static', filename='js/thread_monitor.js') }}"></script>
{% endif %}

{% endblock %}
