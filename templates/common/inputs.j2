
{% macro select(name, options, selected="", generic=false, extra_class="", data_attrs=None) %}
  {% set sel_norm = "" if selected is none else (selected|string)|replace('\t',' ')|trim %}
  {% if options %}
  <select class="form-control{% if extra_class %} {{ extra_class }}{% endif %}" name="{{ name }}" id="{{ name }}"{% if data_attrs %}{% for key, val in data_attrs.items() %} data-{{ key }}="{{ val }}"{% endfor %}{% endif %}>
    {# Cas: options = entier → 0..N #}
    {% if options is integer %}
      {% for n in range(0, options + 1) %}
        {% set n_str = n|string %}
        <option value="{{ n_str }}" {% if n_str == selected|string %}selected{% endif %}>{{ n }}</option>
      {% endfor %}
    {% else %}
      {% if generic %}
        <option value="">{{ "Veuillez sélectionner" }}</option>
      {% elif sel_norm == "" %}
        <option value="" selected></option>
      {% endif %}
      {% for option in options %}
        {% if option is mapping %}
          {% set opt_val  = option.value|string %}
          {% set opt_text = option.text|default(opt_val)|string %}
        {% else %}
          {% set opt_val  = option|string %}
          {% set opt_text = opt_val %}
        {% endif %}
        {% set opt_norm = opt_val|replace('\t',' ')|trim %}
        <option
          value="{{ opt_val }}"
          {% if opt_norm == sel_norm %} selected{% endif %}
        >{{ opt_text }}</option>
      {% endfor %}
    {% endif %}
  </select>
  {% else %}
  <select class="form-control{% if extra_class %} {{ extra_class }}{% endif %}" name="{{ name }}" id="{{ name }}"{% if data_attrs %}{% for key, val in data_attrs.items() %} data-{{ key }}="{{ val }}"{% endfor %}{% endif %}></select>
  {% endif %}
{% endmacro %}


{% macro select_js(name, js, options, selected="") %}
    {% if options %}
    <select class="form-control" name="{{ name }}" id="{{ name }}" onchange="{{ js|replace('"', "'") }}">
        {% if options is integer %}
            {% for n in range(0, options + 1) %}
                <option value="{{ n }}" {% if n == selected %} selected {% endif %}>{{ n }}</option>
            {% endfor %}
        {% else %}
        {% if selected is none or selected == "" %}
            <option value="" selected></option>
        {% endif %}
        {% for option in options %}
            <option value="{{ option }}" {% if option == selected %} selected {% endif %}>{{ option }}</option>
        {% endfor %}
        {% endif %}
    </select>
    {% endif %}
{% endmacro %}

{% macro multichoices(name, options, selected=[]) %}
    {% if options %}
        {% for option in options %}
            <div>
                <input type="checkbox" name="{{ name  }}_{{ option }}", id="{{ option }}" {% if option in selected %}checked{% endif %}> <label for="{{ option }}">{{ option }}</label>
            </div>
        {% endfor %}
    {% endif %}
{% endmacro %}

{% macro check(name, default=None) %}
        <input class="form-check-input" type="checkbox" name="{{ name }}" id="{{ name }}" value="1" {% if default %}checked{% endif %}>
{% endmacro %}

{% macro slider(name, default=None, min=0, max=100) %}
    <input type="range" class="form-range col-sm-2" min="{{ min }}" max="{{ max }}" id="{{ name }}" name="{{ name }}" value="{{ default }}">
{% endmacro %}

{% macro inputstring(name, default=None, focus=False) %}
    <input type="text" name="{{ name }}" id="{{ name }}" {% if default %} value="{{ default }}" {% endif %} class="form-control {% if focus %}focusable{% endif %}" {% if focus %} autofocus {% endif %}>
{% endmacro %}

{% macro inputpassword(name, default=None, focus=False) %}
    <input type="password" name="{{ name }}" id="{{ name }}" {% if default %} value="{{ default }}" {% endif %} class="form-control {% if focus %}focusable{% endif %}" {% if focus %} autofocus {% endif %}>
{% endmacro %}

{% macro inputtext(name, default=None) %}
    <textarea name="{{ name }}" id="{{ name }}" {% if default %} {% endif %} cols="50" rows="5">{{ default | safe }}</textarea>
{% endmacro %}

{% macro folder(name) %}
    <input type="file" class="folder-filepond" name="{{ name }}" id="{{ name }}">
{% endmacro %}

{% macro date(name, default=None) %}
    {% if default and 'T' in default %}
        <input type="datetime-local" name="{{ name }}" id="{{ name }}" {% if default %} value="{{ default }}" {% endif %} class="form-control">
    {% else %}
        <input type="date" name="{{ name }}" id="{{ name }}" {% if default %} value="{{ default }}" {% endif %} class="form-control">
    {% endif %}
{% endmacro %}

{% macro input_js(name, js, default=None, focus=False) %}
    <input type="text" name="{{ name }}" id="{{ name }}" {% if default %} value="{{ default }}" {% endif %} class="form-control {% if focus %}focusable{% endif %}" onchange="{{ js }}">
{% endmacro %}

{% macro path(name, path_variable, default=None) %}
    <div class="row" id="{{ name }}_div">
        <select class="form-control path-select" id="{{ name }}_level0" source="{{ path_variable }}" class="path" onchange="path_add_level('{{ name }}', '{{path_variable}}', 0)">
            <option>Veillez sélectionner</option>
        </select>
        <input class="path_result" type="hidden" name="{{ name }}" id="{{ name }}" {% if default %} value="{{ default }}" {% endif %} class="form-control"> 
    </div>
{% endmacro %}

{% macro hidden(name, value) %}
    <input type="hidden" name="{{ name }}" id="{{ name }}" value="{{ value | e }}">
{% endmacro %}

{% macro number(name, default=None, step=None) %}
    <input type="number" step="{{ step if step is not none else '.01' }}" name="{{ name }}" id="{{ name }}" {% if default %} value="{{ default }}" {% else %} value="0" {% endif %} class="form-control">
{% endmacro %}

{% macro files_level(name, level, levelNb, class) %}
	{% if level %}
		{% for current in level %}
			
				{% if level[current] is not string %}
					<tr>
						<td style="padding-left:{{5+20*levelNb}}px"><i class="mdi mdi-folder" style="margin-right:10px"></i><b>{{ current }}</b></td>
						<td></td>
					</tr>
					
					{{ files_level(name, level[current], levelNb + 1, class)}}
				{% else %}
					<tr>
						<td style="padding-left:{{5+20*levelNb}}px">{{ current }}</td>
						<td style="width:50px"><div class="form-check"><div class="custom-control custom-checkbox"><input type="checkbox" class="from-check-glow form-check-input form-check-{{class}}" name="{{ level[current] }}" value="{{class}}"></div></div></td>
					</tr>
				{% endif %}
		{% endfor %}
	{% endif %}
{% endmacro %}

{% macro files(name, title, files, class, icon, hidden=None) %}
        <h5 class="p-2 text-primary">{{ title }}</h5>
        {% if hidden %}
        <button class="btn btn-primary collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collape{{name}}" aria-expanded="false" aria-controls="collape{{name}}">
            Show file explorer
        </button>

        <div class="collapse" id="collape{{name}}">
        {% endif %}

        
            <table class="table table-striped mb-0">
            <thead>
                <tr>
                        <th>File</th>
                        <th><i class="mdi mdi-{{icon}}"</i></th>
                </tr>
            </thead>
                <tbody>
                {{ files_level(name, files, 0, class) }}
                </tbody>
            </table>
        {% if hidden %}
        </div>
        {% endif %}
    
{% endmacro %}

