{% extends 'base.j2' %}

{% block title %}
{{ t('threads.title') }}
{% endblock %}

{% block main_page %}
{% for thread in threads%}
<div class="card">
    <div class="card-body">
        <h4 class="card-title">
            {{ thread }}
        </h4>
        <div class="card-text" id="thread_{{ thread }}">
            {{threads[thread]}}
        </div>
        <div class="card-footer d-flex justify-content-between">
            <form action="{{ url_for('singles.threads') }}" method="POST" id="kill-form-{{ loop.index }}">
                {{common_input.hidden(thread, "")}}
                <button type="button" class="btn btn-light-danger" onclick="confirmKillThread('{{ thread }}', document.getElementById('kill-form-{{ loop.index }}'))">
                    <i class="mdi mdi-close-circle"></i> {{ t('threads.stop') }}
                </button>
            </form>
        </div>
    </div>
</div>
{% endfor %}

<script>
function confirmKillThread(threadName, form) {
    Swal.fire({
        title: '{{ t("threads.confirm_title") }}',
        text: '{{ t("threads.confirm_text", name="") }}'.replace('""', '"' + threadName + '"'),
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '{{ t("threads.confirm_btn") }}',
        cancelButtonText: '{{ t("threads.cancel_btn") }}'
    }).then(function(result) {
        if (result.isConfirmed) {
            form.submit();
        }
    });
}
</script>
{% endblock %}