{% import 'common/inputs.j2' as common_input %}

{#
    File Upload Widget with FilePond
    
    Displays a complete file upload interface with optional category, subcategory, group_id, and tags.
    Fields are shown only when their value is None/empty, hidden when provided.
    
    Args:
        id: Unique identifier for the upload widget
        text: Label text
        category: Fixed category (hidden if set, shown if None)
        subcategory: Fixed subcategory (hidden if set, shown if None)
        group_id: Fixed group_id (hidden if set, shown if None)
        tags: Fixed tags list (hidden if set, shown if None)
        accept_types: Accepted file types
        multiple: Allow multiple files
        file_manager: FileManager instance (for dropdowns)
#}

{% macro fileupload(id, text, category, subcategory, group_id, tags, accept_types, multiple, file_manager, existing_groups) %}
<div class="file-upload-widget mb-3" id="{{ id }}_widget">
    {% if text %}
    <label class="form-label">{{ text }}</label>
    {% endif %}
    
    {# Category selector (shown only if category is None) - NOT submitted with form #}
    {% if category is none and file_manager %}
    <div class="mb-2">
        <label for="{{ id }}_upload_category" class="form-label">Category</label>
        <select class="form-select" id="{{ id }}_upload_category" data-upload-metadata>
            {% for cat in file_manager.get_categories() %}
            <option value="{{ cat }}">{{ cat|title }}</option>
            {% endfor %}
        </select>
    </div>
    {% endif %}
    
    {# Subcategory input (shown only if subcategory is None) - NOT submitted with form #}
    {% if subcategory is none %}
    <div class="mb-2">
        <label for="{{ id }}_upload_subcategory" class="form-label">Subcategory (Optional)</label>
        <input type="text" class="form-control" id="{{ id }}_upload_subcategory" data-upload-metadata
               placeholder="e.g., 2025, project_name">
    </div>
    {% endif %}
    
    {# Group ID selector (shown only if group_id is None) - NOT submitted with form #}
    {% if group_id is none and file_manager %}
    <div class="mb-2">
        <label for="{{ id }}_upload_group_id" class="form-label">Group ID (Optional - for versioning)</label>
        <input type="text" class="form-control" id="{{ id }}_upload_group_id" data-upload-metadata
               placeholder="Enter group ID or leave empty" list="{{ id }}_group_list">
        <datalist id="{{ id }}_group_list">
            {% for group_name in existing_groups %}
            <option value="{{ group_name }}">
            {% endfor %}
        </datalist>
        <div class="form-text">Files with the same group_id and filename are versioned</div>
    </div>
    {% endif %}
    
    {# Tags multi-select (shown only if tags is None) - NOT submitted with form #}
    {% if tags is none and file_manager %}
    <div class="mb-2">
        <label for="{{ id }}_upload_tags" class="form-label">Tags (Optional)</label>
        <select class="form-select" id="{{ id }}_upload_tags" data-upload-metadata multiple>
            {% for tag in file_manager.get_tags() %}
            <option value="{{ tag }}">{{ tag }}</option>
            {% endfor %}
        </select>
        <div class="form-text">Hold Ctrl/Cmd to select multiple tags</div>
    </div>
    {% endif %}
    
    {# FilePond file input - NOT submitted with form (FilePond handles upload) #}
    <div class="mb-2">
        <input type="file" 
               class="filepond-upload" 
               id="{{ id }}_filepond" 
               data-upload-metadata
               {% if accept_types %}
               data-accept-types="{{ accept_types|join(',') }}"
               {% endif %}
               {% if multiple %}
               multiple
               {% endif %}>
    </div>
    
    {# Hidden field to store uploaded file ID - ONLY field submitted with form #}
    {# Pre-fill with existing files for arrays (as JSON objects joined with #) #}
    {% if existing_values %}
    <input type="hidden" id="{{ id }}" name="{{ id }}" value="{{ existing_values | map('tojson') | join('#') }}" data-initial-value="{{ existing_values | map('tojson') | join('#') }}">
    {% else %}
    <input type="hidden" id="{{ id }}" name="{{ id }}" value="">
    {% endif %}
    
    {# Upload result message area #}
    <div id="{{ id }}_result" class="mt-2"></div>
    
    {# Debug info #}
    <div class="form-text text-muted">Field ID: {{ id }} (only this field with file ID will be submitted)</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const inputElement = document.getElementById('{{ id }}_filepond');
    
    if (inputElement && typeof FilePond !== 'undefined') {
        console.log('[FileUpload {{ id }}] Initializing FilePond');
        
        // Create FilePond instance
        const pond = FilePond.create(inputElement, {
            allowMultiple: {{ 'true' if multiple else 'false' }},
            maxParallelUploads: 1,  // Upload files sequentially to prevent DB conflicts
            {% if accept_types %}
            acceptedFileTypes: {{ accept_types|tojson }},
            {% endif %}
            server: {
                process: {
                    url: '/files/upload',
                    method: 'POST',
                    onload: (response) => {
                        const data = JSON.parse(response);
                        console.log('[FileUpload {{ id }}] Upload response:', data);
                        return data.file.id;
                    },
                    onerror: (response) => {
                        const data = JSON.parse(response);
                        console.error('[FileUpload {{ id }}] Upload error:', data);
                    }
                }
            },
            onprocessfile: (error, file) => {
                if (!error) {
                    console.log('[FileUpload {{ id }}] File uploaded:', file.filename);
                }
            }
        });
        
        // Before upload, add metadata to form data
        pond.setOptions({
            server: {
                process: (fieldName, file, metadata, load, error, progress, abort) => {
                    const formData = new FormData();
                    formData.append('file', file, file.name);
                    
                    console.log('[FileUpload {{ id }}] Preparing upload for:', file.name);
                    
                    // Add category (from visible field or pre-filled value)
                    const categoryField = document.getElementById('{{ id }}_upload_category');
                    const category = categoryField ? categoryField.value : '{{ category if category else "" }}';
                    if (category) {
                        formData.append('category', category);
                        console.log('[FileUpload {{ id }}] Category:', category);
                    }
                    
                    // Add subcategory (from visible field or pre-filled value)
                    const subcategoryField = document.getElementById('{{ id }}_upload_subcategory');
                    const subcategory = subcategoryField ? subcategoryField.value : '{{ subcategory if subcategory else "" }}';
                    if (subcategory) {
                        formData.append('subcategory', subcategory);
                        console.log('[FileUpload {{ id }}] Subcategory:', subcategory);
                    }
                    
                    // Add group_id (from visible field or pre-filled value)
                    const groupIdField = document.getElementById('{{ id }}_upload_group_id');
                    const group_id = groupIdField ? groupIdField.value : '{{ group_id if group_id else "" }}';
                    if (group_id) {
                        formData.append('group_id', group_id);
                        console.log('[FileUpload {{ id }}] Group ID:', group_id);
                    }
                    
                    // Add tags (from visible field or pre-filled value)
                    const tagsField = document.getElementById('{{ id }}_upload_tags');
                    let tags = [];
                    if (tagsField) {
                        tags = Array.from(tagsField.selectedOptions).map(opt => opt.value);
                    } else {
                        // Pre-filled tags
                        tags = {{ tags|tojson if tags else '[]' }};
                    }
                    if (tags.length > 0) {
                        formData.append('tags', tags.join(','));
                        console.log('[FileUpload {{ id }}] Tags:', tags);
                    }
                    
                    // Upload with fetch
                    const request = new XMLHttpRequest();
                    request.open('POST', '/files/upload');
                    
                    request.upload.onprogress = (e) => {
                        progress(e.lengthComputable, e.loaded, e.total);
                    };
                    
                    request.onload = function() {
                        if (request.status >= 200 && request.status < 300) {
                            const data = JSON.parse(request.responseText);
                            console.log('[FileUpload {{ id }}] Upload response:', data);
                            if (data.success) {
                                // Store versioned file reference as JSON string for form submission
                                const hiddenField = document.getElementById('{{ id }}');
                                if (hiddenField) {
                                    const versionedRef = JSON.stringify({
                                        file_id: data.file.id,
                                        version: data.file.version || 1
                                    });
                                    
                                    {% if multiple %}
                                    // Array mode: append with # separator
                                    if (hiddenField.value) {
                                        hiddenField.value += '#' + versionedRef;
                                        console.log('[FileUpload {{ id }}] ✓ Appended file to array:', versionedRef);
                                    } else {
                                        hiddenField.value = versionedRef;
                                        console.log('[FileUpload {{ id }}] ✓ First file in array:', versionedRef);
                                    }
                                    console.log('[FileUpload {{ id }}] Array value:', hiddenField.value);
                                    {% else %}
                                    // Single mode: replace value
                                    hiddenField.value = versionedRef;
                                    console.log('[FileUpload {{ id }}] ✓ Stored versioned file reference in hidden field "{{ id }}":', versionedRef);
                                    console.log('[FileUpload {{ id }}] Hidden field will be submitted as: {{ id }}=' + versionedRef);
                                    {% endif %}
                                } else {
                                    console.error('[FileUpload {{ id }}] ✗ Hidden field "{{ id }}" not found!');
                                }
                                load(data.file.id);
                            } else {
                                console.error('[FileUpload {{ id }}] Upload failed:', data);
                                error('Upload failed');
                            }
                        } else {
                            try {
                                const data = JSON.parse(request.responseText);
                                console.error('[FileUpload {{ id }}] Upload error response:', data);
                            } catch(e) {
                                console.error('[FileUpload {{ id }}] Upload error (no JSON):', request.responseText);
                            }
                            error('Upload failed');
                        }
                    };
                    
                    request.onerror = function() {
                        error('Network error');
                    };
                    
                    request.send(formData);
                    
                    return {
                        abort: () => {
                            request.abort();
                            abort();
                        }
                    };
                }
            }
        });
        
        // PROTECT HIDDEN FIELD: Prevent form submission from clearing pre-filled values
        // This ensures existing files are preserved when saving without uploading new files
        const form = inputElement.closest('form');
        if (form) {
            const hiddenField = document.getElementById('{{ id }}');
            
            form.addEventListener('submit', function(e) {
                const initialValue = hiddenField.getAttribute('data-initial-value') || '';
                // If hidden field is empty but had initial value, restore it
                if (hiddenField && !hiddenField.value && initialValue) {
                    console.log('[FileUpload {{ id }}] Restoring hidden field value on submit:', initialValue);
                    hiddenField.value = initialValue;
                }
            }, true);  // Use capture phase to run BEFORE other handlers
        }
    }
});
</script>
{% endmacro %}
