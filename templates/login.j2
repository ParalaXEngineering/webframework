{% import 'common/inputs.j2' as common_input %}
{% import 'common/controls.j2' as common_controls %}

<!DOCTYPE html>
<html lang="{{ current_lang | default('en') }}">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - {{ web_title }}</title>
    {% block stylesfirst %}{% endblock %}
    {% block styles %}{% endblock %}
    <link rel="stylesheet" href="{{ url_for('static', filename= 'vendors/mdi/css/materialdesignicons.min.css') }}">
	<link rel="stylesheet" href="{{ url_for('static', filename= 'css/app.css') }}">
	<link rel="stylesheet" href="{{ url_for('static', filename= 'css/app-dark.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename= 'css/auth.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename= 'vendors/sweetalert/sweetalert2.min.css') }}">
    <link rel="shortcut icon" href="{{ url_for('common.assets', asset_type="images", filename= 'logo/favicon.png') }}" type="image/png">
    
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
</head>

<body>

        <div id="auth">

        <div class="row h-100">
            <div class="col-lg-5 col-12">
                <div id="auth-left">
                    <div class="auth-logo">
                        <h3><i class="mdi mdi-{{app["icon"]}}"></i>{{app["name"]}}</h3>
                        <h4><small>{{app["version"]}}</small></h4>
                    </div>
                    <h1 class="auth-title">{{ t('login.title') }}</h1>
                    <p class="auth-subtitle mb-5">{{ t('login.subtitle') }}</p>

                    <form action="{{ url_for(target) }}" method="POST" id="loginForm">
                        <div class="form-group position-relative has-icon-left mb-4">
                            <select class="form-control form-control-xl" name="user" id="user">
                                    {% for user in users %}
                                        <option>{{ user }}</option>
                                    {% endfor %}
                                </select>
                            <div class="form-control-icon">
                                <i class="bi bi-person"></i>
                            </div>
                        </div>
                        <div class="form-group position-relative has-icon-left mb-4">
                            <input type="password" class="form-control form-control-xl" placeholder="{{ t('login.password') }}" name="password" id="password" onkeypress="if(event.key === 'Enter' || event.keyCode === 13) { event.preventDefault(); {% if otp_required|default(false) %}document.getElementById('otp_code').focus();{% else %}document.getElementById('loginForm').submit();{% endif %} }" {% if on_target|default(false) and cooldown_remaining|default(0) > 0 %}disabled{% endif %}>
                            <div class="form-control-icon">
                                <i class="bi bi-shield-lock"></i>
                            </div>
                        </div>
                        <div id="capslock-warning" class="alert alert-warning d-flex align-items-center py-2 mb-3" role="alert" style="display: none !important;">
                            <i class="mdi mdi-alert-circle-outline me-2" style="font-size: 1.2rem;"></i>
                            <span>{{ t('login.caps_lock') }}</span>
                        </div>
                        
                        {% if otp_required|default(false) %}
                        <div class="form-group position-relative has-icon-left mb-4">
                            <input type="text" class="form-control form-control-xl" placeholder="{{ t('login.otp') }}" name="otp_code" id="otp_code" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code" onkeypress="if(event.key === 'Enter' || event.keyCode === 13) { event.preventDefault(); document.getElementById('loginForm').submit(); }" {% if on_target|default(false) and cooldown_remaining|default(0) > 0 %}disabled{% endif %}>
                            <div class="form-control-icon">
                                <i class="bi bi-key"></i>
                            </div>
                        </div>
                        {% endif %}
                        
                        {% if message %}
                        <div class="alert alert-danger" role="alert">
                            {{ message }}
                            {% if on_target|default(false) and cooldown_remaining|default(0) > 0 %}
                                <div id="cooldown-timer" class="mt-2">
                                    <strong>{{ t('login.time_remaining') }}: <span id="cooldown-seconds">{{ cooldown_remaining }}</span>s</strong>
                                </div>
                            {% endif %}
                            {% if on_target|default(false) and attempts_remaining is defined %}
                                <div class="mt-2">
                                    <strong>{{ t('login.attempts_remaining') }}: {{ attempts_remaining }}/5</strong>
                                </div>
                            {% endif %}
                        </div>
                        {% endif %}

                        <button type="submit" class="btn btn-primary btn-block btn-lg shadow-lg mt-5" id="login-button" {% if on_target|default(false) and cooldown_remaining|default(0) > 0 %}disabled{% endif %}>{{ t('login.button') }}</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-7 d-none d-lg-block text-center">
                <div id="auth-right" class="d-flex align-items-center">
                    {% set suffix = '_4target' if on_target|default(false) else '' %}
                    <img class="rounded-circle mx-auto"
                        id="avatar"
                        src="{{ url_for('common.assets',
                                        asset_type='images',
                                        filename='users/' + users[0] + suffix + '.jpg') }}"
                        width="512px">
                </div>
            </div>

        </div>

    </div>
    <script src="{{ url_for('static', filename= 'vendors/jquery/jquery.min.js') }}"></script>
    <script src="{{ url_for('static', filename= 'vendors/sweetalert/sweetalert2.min.js') }}"></script>
    <script>
        // Variable globale injectée depuis Jinja
        var onTarget = {{ 'true' if on_target else 'false' }};
        var cooldownRemaining = {{ cooldown_remaining|default(0) }};
        var otpRequired = {{ 'true' if otp_required|default(false) else 'false' }};

        // =====================================================
        // Auth page heartbeat for OTP overlay (OnTarget only)
        // Sends a heartbeat every 2 seconds to signal that
        // someone is on the auth page -> OTP overlay displays
        // =====================================================
        var heartbeatInterval = null;
        
        function startAuthHeartbeat() {
            if (!onTarget || !otpRequired) return;
            
            // Send initial heartbeat
            sendHeartbeat();
            
            // Start interval (every 2 seconds)
            heartbeatInterval = setInterval(sendHeartbeat, 2000);
        }
        
        function sendHeartbeat() {
            fetch('/auth/heartbeat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            }).catch(function(err) {
                console.log('Heartbeat failed:', err);
            });
        }
        
        function stopAuthHeartbeat() {
            if (heartbeatInterval) {
                clearInterval(heartbeatInterval);
                heartbeatInterval = null;
            }
            // Notify server that user is leaving
            if (onTarget && otpRequired) {
                navigator.sendBeacon('/auth/close', '{}');
            }
        }
        
        // Start heartbeat when page loads
        document.addEventListener('DOMContentLoaded', startAuthHeartbeat);
        
        // Stop heartbeat and notify server when leaving page
        window.addEventListener('beforeunload', stopAuthHeartbeat);
        window.addEventListener('pagehide', stopAuthHeartbeat);
        
        // =====================================================

        // Cooldown timer for OnTarget mode
        if (onTarget && cooldownRemaining > 0) {
            var countdownInterval = setInterval(function() {
                cooldownRemaining--;
                var timerElement = document.getElementById('cooldown-seconds');
                if (timerElement) {
                    timerElement.textContent = cooldownRemaining;
                }
                
                if (cooldownRemaining <= 0) {
                    clearInterval(countdownInterval);
                    // Re-enable the password field and button
                    document.getElementById('password').disabled = false;
                    document.getElementById('password').value = '';
                    document.getElementById('login-button').disabled = false;
                    // Re-enable OTP field if present
                    var otpField = document.getElementById('otp_code');
                    if (otpField) {
                        otpField.disabled = false;
                        otpField.value = '';
                    }
                    // Remove the error message
                    var alertDiv = document.querySelector('.alert-danger');
                    if (alertDiv) {
                        alertDiv.style.display = 'none';
                    }
                }
            }, 1000);
        }

        function updateImage() {
            var selectElement = document.getElementById("user");
            var avatarElement = document.getElementById("avatar");

            var selectedUser = selectElement.value;

            // Déterminer le suffix
            var suffix = onTarget ? "_4target" : "";

            avatarElement.classList.add("fade-out");

            setTimeout(function() {
                avatarElement.src = "/common/assets/images/?filename=users/" + selectedUser + suffix + ".jpg";

                // fallback automatique si l'image n'existe pas
                avatarElement.onerror = function() {
                    this.onerror = null; // éviter boucle infinie
                    this.src = "/common/assets/images/?filename=users/" + selectedUser + ".jpg";
                };

                avatarElement.classList.remove("fade-out");
            }, 500);
        }

        document.addEventListener("DOMContentLoaded", updateImage);

        var selectElement = document.getElementById("user");
        selectElement.addEventListener("change", updateImage);

        // Caps Lock detection
        (function() {
            var capsWarning = document.getElementById('capslock-warning');
            function checkCapsLock(e) {
                if (e.getModifierState && typeof e.getModifierState === 'function') {
                    var capsOn = e.getModifierState('CapsLock');
                    capsWarning.style.setProperty('display', capsOn ? 'flex' : 'none', 'important');
                }
            }
            var pwdField = document.getElementById('password');
            ['keydown', 'keyup', 'mousedown', 'focus'].forEach(function(evt) {
                pwdField.addEventListener(evt, checkCapsLock);
            });
            var otpField = document.getElementById('otp_code');
            if (otpField) {
                ['keydown', 'keyup', 'mousedown', 'focus'].forEach(function(evt) {
                    otpField.addEventListener(evt, checkCapsLock);
                });
            }
        })();
    </script>

    <script src="{{ url_for('static', filename= 'js/socket.io.min.js') }}"></script>
    <script src="{{ url_for('static', filename= 'js/app.js') }}"></script>
    <script src="{{ url_for('static', filename= 'js/site.js') }}"></script>
    {% for script in javascript %}
        <script src="{{ url_for('common.assets', asset_type="js", filename= script) }}"></script>
    {% endfor %}
    {% block js %}{% endblock %}
    
    <script>
        // Soumission du formulaire avec Enter - CODE EN DERNIER pour éviter les conflits
        $(document).ready(function() {
            $('#password').on('keypress keydown', function(e) {
                if (e.which === 13 || e.keyCode === 13) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    // If OTP required, focus on OTP field instead of submitting
                    if (otpRequired && document.getElementById('otp_code')) {
                        $('#otp_code').focus();
                    } else {
                        $('#loginForm').submit();
                    }
                    return false;
                }
            });
            
            $('#user').on('keypress keydown', function(e) {
                if (e.which === 13 || e.keyCode === 13) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    $('#password').focus();
                    return false;
                }
            });
            
            // OTP field - submit on Enter
            $('#otp_code').on('keypress keydown', function(e) {
                if (e.which === 13 || e.keyCode === 13) {
                    e.preventDefault();
                    e.stopPropagation();
                    e.stopImmediatePropagation();
                    $('#loginForm').submit();
                    return false;
                }
            });
        });
    </script>
</body>

</html>